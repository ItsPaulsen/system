{
  "name": "system",
  "version": "0.0.0",
  "private": true,
  "description": "Design-system reference site — system.kristianpaulsen.com",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input",
    "lint:js": "eslint .",
    "lint:html": "html-validate \"**/*.html\"",
    "lint": "npm run format:check && npm run lint:css && npm run lint:js && npm run lint:html"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "html-validate": "^9.5.5",
    "prettier": "^3.4.2",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^37.0.0"
  }
}
